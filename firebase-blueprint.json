{
  "entities": {
    "SpreadsheetData": {
      "title": "SpreadsheetData",
      "description": "User's uploaded spreadsheet data",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The UID of the user who owns this data"
        },
        "rawData": {
          "type": "string",
          "description": "JSON stringified raw data to easily bypass query limits on arrays of objects"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "rawData", "createdAt", "updatedAt"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "description": "Global application settings such as validadeInputs",
      "type": "object",
      "properties": {
        "inputs": {
          "type": "object",
          "description": "Record of validade inputs per SKU"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "firestore": {
    "/spreadsheets/{spreadsheetId}": {
      "schema": {
        "$ref": "#/entities/SpreadsheetData"
      },
      "description": "Stores user spreadsheets. Usually spreadsheetId is the userId."
    },
    "/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/AppSetting"
      },
      "description": "Stores global app settings"
    }
  }
}
