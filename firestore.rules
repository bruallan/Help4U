rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    match /spreadsheets/{spreadsheetId} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /sales/{saleId} {
      allow read, write: if true;
    }

    match /syncStatus/{docId} {
      allow read, write: if true;
    }
  }
}
